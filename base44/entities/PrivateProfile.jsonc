{
  "name": "PrivateProfile",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Reference to the auth user ID that owns this private profile data"
    },
    "display_name": {
      "type": "string",
      "description": "Real name, revealed only after the server/client unlock policy allows it"
    },
    "bio": {
      "type": "string",
      "description": "Private bio text"
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Private interest tags"
    },
    "photo_url": {
      "type": "string",
      "description": "Primary private profile photo URL"
    },
    "photo_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 6,
      "description": "Private profile photo URLs, capped at 6 total uploads"
    }
  },
  "required": [
    "user_id"
  ]
}
